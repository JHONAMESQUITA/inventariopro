# ─────────────────────────────────────────────
#  BASE DE DATOS
# ─────────────────────────────────────────────
def init_db():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS movimientos (
        id             INTEGER PRIMARY KEY AUTOINCREMENT,
        nombre         TEXT,
        material       TEXT,
        sku            TEXT,
        cantidad       REAL,
        tipo           TEXT,
        fecha          TEXT,
        stock_registro REAL,
        dias           INTEGER,
        retorno        TEXT DEFAULT "N/A",
        notas          TEXT DEFAULT "",
        ubicacion      TEXT DEFAULT ""
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS limpieza (
        id       INTEGER PRIMARY KEY AUTOINCREMENT,
        material TEXT,
        cantidad REAL,
        estado   TEXT,
        fecha    TEXT,
        notas    TEXT DEFAULT ""
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS alertas_stock (
        id           INTEGER PRIMARY KEY AUTOINCREMENT,
        material     TEXT UNIQUE,
        stock_minimo REAL DEFAULT 5
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS ubicaciones (
        id     INTEGER PRIMARY KEY AUTOINCREMENT,
        nombre TEXT UNIQUE
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS auditoria (
        id        INTEGER PRIMARY KEY AUTOINCREMENT,
        accion    TEXT,
        detalle   TEXT,
        fecha     TEXT,
        usuario   TEXT DEFAULT "sistema"
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS actualizaciones_correo (
        id           INTEGER PRIMARY KEY AUTOINCREMENT,
        fecha        TEXT,
        remitente    TEXT,
        asunto       TEXT,
        archivo      TEXT,
        insertados   INTEGER,
        omitidos     INTEGER,
        errores      INTEGER
    )''')
    for tabla, columna, definicion in [
        ("movimientos", "notas",    "TEXT DEFAULT ''"),
        ("movimientos", "ubicacion","TEXT DEFAULT ''"),
        ("limpieza",    "notas",    "TEXT DEFAULT ''"),
    ]:
        try:
            c.execute(f"ALTER TABLE {tabla} ADD COLUMN {columna} {definicion}")
        except sqlite3.OperationalError:
            pass
    conn.commit()
    conn.close()

init_db()

# ─────────────────────────────────────────────
#  UTILIDADES BD
# ─────────────────────────────────────────────
def db_query(sql, params=(), fetchall=True):
    conn = sqlite3.connect(DB_PATH)
    try:
        c = conn.cursor()
        c.execute(sql, params)
        return c.fetchall() if fetchall else c.fetchone()
    finally:
        conn.close()

def db_execute(sql, params=()):
    conn = sqlite3.connect(DB_PATH)
    try:
        c = conn.cursor()
        c.execute(sql, params)
        conn.commit()
        return c.lastrowid
    except sqlite3.Error as e:
        conn.rollback()
        raise e
    finally:
        conn.close()

def log_auditoria(accion, detalle):
    try:
        db_execute(
            "INSERT INTO auditoria (accion, detalle, fecha) VALUES (?,?,?)",
            (accion, detalle, datetime.now().strftime("%d/%m/%Y %H:%M:%S"))
        )
    except Exception:
        pass

