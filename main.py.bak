# ─────────────────────────────────────────────
#  CAPTURA GLOBAL DE ERRORES — evita crashes silenciosos
# ─────────────────────────────────────────────
def _guardar_crash(tipo, valor, tb):
    try:
        ruta = os.path.join(os.path.dirname(os.path.abspath(__file__)), "crash_log.txt")
        with open(ruta, "w", encoding="utf-8") as f:
            f.write(f"CRASH {datetime.now()}\n")
            traceback.print_exception(tipo, valor, tb, file=f)
    except Exception:
        pass

sys.excepthook = _guardar_crash

