            disabled: True
            on_release: root.importar()

        Button:
            text: "← VOLVER"
            size_hint_y: None
            height: dp(46)
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'
'''

# ─────────────────────────────────────────────
#  PANTALLAS
# ─────────────────────────────────────────────

class InventarioScreen(Screen):
    def on_enter(self):
        self.actualizar_spinners()
        self._verificar_alertas_silencioso()
        self._actualizar_dashboard()
        self._cargar_actividad_reciente()
        try:
            self.ids.info_carpeta.text = f"Exportaciones: {EXPORT_DIR}"
        except Exception:
            pass
        gc.collect()

    def actualizar_spinners(self):
        try:
            nombres    = sorted({str(r[0]).upper() for r in db_query("SELECT DISTINCT nombre FROM movimientos") if r[0]})
            materiales = sorted({str(r[0]).upper() for r in db_query("SELECT DISTINCT material FROM movimientos") if r[0]})
            self.ids.responsable_spinner.values = nombres
            self.ids.producto_spinner.values    = materiales
        except Exception:
            pass

    def _verificar_alertas_silencioso(self):
        try:
            alertas = obtener_alertas_activas()
            if alertas:
                n = len(alertas)
                self.ids.info.text = f"[color=#F59E0B]{n} alerta{'s' if n > 1 else ''} de stock[/color]"
                self.ids.btn_alertas.text = f"ALERTAS ({n})"
                self.ids.btn_alertas.background_color = get_color_from_hex('#DC2626')
            else:
                self.ids.btn_alertas.text = "ALERTAS"
                self.ids.btn_alertas.background_color = get_color_from_hex('#1E293B')
        except Exception:
            pass

    def _actualizar_dashboard(self):
        """Actualiza las tarjetas de resumen del dashboard."""
        try:
            hora = datetime.now().hour
            if hora < 7:
                saludo = "🌙 Buenas noches"
            elif hora < 12:
                saludo = "☀️ Buenos dias"
            elif hora < 18:
                saludo = "🌤️ Buenas tardes"
            else:
                saludo = "🌙 Buenas noches"
            self.ids.lbl_saludo.text = saludo

            meses = ['enero','febrero','marzo','abril','mayo','junio',
                     'julio','agosto','septiembre','octubre','noviembre','diciembre']
            ahora = datetime.now()
            self.ids.lbl_fecha_hoy.text = f"{ahora.day} de {meses[ahora.month-1]} {ahora.year}  •  {ahora.strftime('%H:%M')}"

            total_mat = db_query("SELECT COUNT(DISTINCT material) FROM movimientos", fetchall=False)[0] or 0
            self.ids.stat_materiales.text = str(total_mat)

            hoy = ahora.strftime("%d/%m/%Y")
            movs_hoy = db_query(f"SELECT COUNT(*) FROM movimientos WHERE fecha LIKE '{hoy}%'", fetchall=False)[0] or 0
            self.ids.stat_movs_hoy.text = str(movs_hoy)

            # FIX: stat_alertas muestra alertas de stock (no pendientes de retorno).
            # stat_pendientes muestra materiales que están fuera sin retornar.
            alertas = obtener_alertas_activas()
            self.ids.stat_alertas.text = str(len(alertas))

            # FIX: Calcular correctamente los materiales pendientes de retorno
            # usando la lógica de saldo (salidas - entradas de no-inventario).
            prestamos_activos = obtener_equipos_en_prestamo()
            self.ids.stat_pendientes.text = str(len(prestamos_activos))

            try:
                size_kb = os.path.getsize(DB_PATH) / 1024
                self.ids.lbl_resumen_db.text = f"BD: {size_kb:.0f} KB"
            except Exception:
                pass
        except Exception:
            pass

    def _cargar_actividad_reciente(self):
        """Muestra los últimos 5 movimientos como feed de actividad."""
        try:
            self.ids.actividad_reciente.clear_widgets()
            movs = db_query(
                "SELECT nombre, material, cantidad, tipo, fecha FROM movimientos ORDER BY id DESC LIMIT 5"
            )
            if not movs:
                self.ids.actividad_reciente.add_widget(
                    Label(text="Sin movimientos registrados",
                          color=get_color_from_hex('#475569'),
                          size_hint_y=None, height=dp(30), font_size='12sp')
                )
                return
            for nombre, material, cantidad, tipo, fecha in movs:
                if tipo == "ENTRADA":
                    icono = "▲"
                    color_hex = '#4ADE80'
                else:
                    icono = "▼"
                    color_hex = '#F87171'
                fecha_corta = str(fecha)[:16] if fecha else ""
                texto = (
                    f"[color={color_hex}]{icono}[/color] "
                    f"[b]{material}[/b]  x{cantidad}  "
                    f"[color=#64748B]{nombre} • {fecha_corta}[/color]"
                )
                lbl = Label(
                    text=texto,
                    markup=True,
                    font_size='11sp',
                    color=get_color_from_hex('#CBD5E1'),
                    size_hint_y=None,
                    height=dp(28),
                    halign='left',
                    text_size=(Window.width * 0.85, None),
                )
                self.ids.actividad_reciente.add_widget(lbl)
        except Exception:
            pass

    def mostrar_alertas(self):
        rows = db_query(
            "SELECT nombre,material,sku,cantidad,tipo,fecha,notas FROM movimientos "
            "WHERE UPPER(nombre) != 'INVENTARIO' ORDER BY id ASC"
        )
        actualmente_fuera = {}
        for n, m, s, c, t, f, notas in rows:
            key = f"{n}|{m}"
            if t == "SALIDA":
                if key not in actualmente_fuera:
                    actualmente_fuera[key] = [n, m, s, float(c), t, f, notas or ""]
                else:
                    actualmente_fuera[key][3] += float(c)
            elif t == "ENTRADA" and key in actualmente_fuera:
                actualmente_fuera[key][3] -= float(c)
                if actualmente_fuera[key][3] <= 0:
                    del actualmente_fuera[key]

        pendientes = list(actualmente_fuera.values())
        content = BoxLayout(orientation='vertical', padding=dp(10), spacing=dp(8))
        pop = Popup(title=f"⚠ MATERIALES SIN RETORNAR ({len(pendientes)})",
                    content=content, size_hint=(0.93, 0.82))
        if not pendientes:
            content.add_widget(Label(text="✓ Todo en orden — ningún material pendiente de retorno.",
                                     color=get_color_from_hex('#10B981'), halign='center'))
        else:
            sv = ScrollView()
            gl = GridLayout(cols=1, size_hint_y=None, spacing=dp(8))
            gl.bind(minimum_height=gl.setter('height'))
            for item in sorted(pendientes, key=lambda x: x[0]):
                n, m, s, c, _, f, notas = item
                tiene_notas = bool(notas and notas.strip())
                altura = dp(110) if tiene_notas else dp(80)
                card = crear_tarjeta(altura, '#3B1A00')
                card.add_widget(Label(
                    text=f"[b]{m}[/b]  —  Responsable: [color=#F59E0B]{n}[/color]",
                    markup=True, color=get_color_from_hex('#F87171'),
                    size_hint_y=None, height=dp(24),
                    halign='left', text_size=(Window.width * 0.82, None)
                ))
                card.add_widget(Label(
                    text=f"Cantidad fuera: [b]{round(c,2)}[/b]  |  SKU: {s or 'N/A'}  |  Salida: {f}",
                    color=get_color_from_hex('#FCA5A5'), font_size='12sp',
                    size_hint_y=None, height=dp(20),
                    halign='left', text_size=(Window.width * 0.82, None)
                ))
                if tiene_notas:
                    card.add_widget(Label(
                        text=f"[color=#94A3B8]Notas:[/color] [color=#E2E8F0]{notas}[/color]",
                        markup=True, font_size='11sp',
                        size_hint_y=None, height=dp(22),
                        halign='left', text_size=(Window.width * 0.82, None)
                    ))
                gl.add_widget(card)
            sv.add_widget(gl)
            content.add_widget(sv)
        content.add_widget(Button(text="CERRAR", size_hint_y=None, height=dp(45),
                                   background_color=get_color_from_hex('#334155'),
                                   on_release=pop.dismiss))
        pop.open()

    def chequear_actualizacion(self):
        self.ids.info.text = "Buscando actualizacion..."
        if not REQUESTS_AVAILABLE:
            self.ids.info.text = "requests no instalado"
            return
        threading.Thread(target=self._hilo_descarga, daemon=True).start()

    def _hilo_descarga(self):
        try:
            r = requests.get(URL_NUEVA_APK, stream=True, timeout=15)
            if r.status_code == 200:
                ruta = "update_inventario.apk" if platform == 'android' else "update_inventario.exe"
                with open(ruta, 'wb') as f:
                    for chunk in r.iter_content(chunk_size=4096):
                        if chunk: f.write(chunk)
                Clock.schedule_once(lambda dt: self._instalar_apk(ruta))
            else:
                Clock.schedule_once(lambda dt: setattr(self.ids.info, 'text', "Archivo no encontrado"))
        except Exception:
            Clock.schedule_once(lambda dt: setattr(self.ids.info, 'text', "Error de red"))

    def _instalar_apk(self, ruta):
        self.ids.info.text = "Instalando..."
        if platform == 'android':
            try:
                from jnius import autoclass
                PythonActivity = autoclass('org.kivy.android.PythonActivity')
                Intent = autoclass('android.content.Intent')
                Uri    = autoclass('android.net.Uri')
                File   = autoclass('java.io.File')
                intent = Intent(Intent.ACTION_VIEW)
                intent.setDataAndType(Uri.fromFile(File(ruta)), "application/vnd.android.package-archive")
                intent.setFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                PythonActivity.mActivity.startActivity(intent)
            except Exception:
                self.ids.info.text = "Error en instalador"
        else:
            self.ids.info.text = f"Guardado: {ruta}"

    def actualizar_desde_correo(self):
        """Abre el popup de progreso y lanza el actualizador."""
        self._popup_correo = self._crear_popup_progreso()
        self._popup_correo.open()

        actualizador = ActualizadorCorreo(
            callback_progreso=self._actualizar_progreso_correo,
            callback_fin=self._finalizar_actualizacion_correo,
        )
        actualizador.ejecutar()

    def _crear_popup_progreso(self):
        content = BoxLayout(orientation='vertical', padding=dp(15), spacing=dp(12))
        pop = Popup(
            title="Actualizando desde correo...",
            content=content,
            size_hint=(0.92, 0.55),
            auto_dismiss=False,
        )
        self._lbl_progreso = Label(
            text="Iniciando...",
            color=get_color_from_hex('#38BDF8'),
            halign='center',
            font_size='14sp',
            text_size=(Window.width * 0.85, None),
        )
        content.add_widget(self._lbl_progreso)
        btn_cerrar = Button(
            text="⏳ Procesando... (toca para cerrar si ya terminó)",
            size_hint_y=None, height=dp(46),
            background_color=get_color_from_hex('#334155'),
        )
        btn_cerrar.bind(on_release=pop.dismiss)
        content.add_widget(btn_cerrar)
        self._btn_cerrar_popup = btn_cerrar
        return pop

    def _actualizar_progreso_correo(self, texto):
        try:
            self._lbl_progreso.text = texto
        except Exception:
            pass

    def _finalizar_actualizacion_correo(self, exito, datos):
        try:
            self._popup_correo.dismiss()
        except Exception:
            pass

        if exito:
            self._mostrar_resultado_correo(datos)
            self.actualizar_spinners()
        else:
            self._mostrar_error_correo(datos.get("error", "Error desconocido"))

    def _mostrar_resultado_correo(self, datos):
        """Popup de éxito con resumen de la importación."""
