#:import utils kivy.utils
#:import dp kivy.metrics.dp

<AjustesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: [dp(5), 0]
            Label:
                text: "AJUSTES"
                font_size: '18sp'
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'
                color: utils.get_color_from_hex('#5A6A7A')

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(12)
                padding: dp(5)

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(180)
                    spacing: dp(8)
                    padding: dp(12)
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#0D1B2A')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(4)]
                        Color:
                            rgba: utils.get_color_from_hex('#1A2A4A')
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                            width: dp(1)
                    Label:
                        text: "ALERTAS DE STOCK MINIMO"
                        bold: True
                        color: utils.get_color_from_hex('#FF0044')
                        size_hint_y: None
                        height: dp(30)
                    Spinner:
                        id: alerta_material_spinner
                        text: "SELECCIONAR MATERIAL"
                        values: []
                        size_hint_y: None
                        height: dp(45)
                    BoxLayout:
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(45)
                        TextInput:
                            id: stock_minimo_input
                            hint_text: "Stock minimo (ej: 5)"
                            input_filter: 'float'
                            multiline: False
                        Button:
                            text: "GUARDAR"
                            size_hint_x: None
                            width: dp(100)
                            background_color: utils.get_color_from_hex('#0066FF')
                            on_release: root.guardar_alerta()
                    Label:
                        id: info_alerta
                        text: ""
                        color: utils.get_color_from_hex('#00D4FF')
                        size_hint_y: None
                        height: dp(22)

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(230)
                    spacing: dp(8)
                    padding: dp(12)
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#0D1B2A')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(4)]
                        Color:
                            rgba: utils.get_color_from_hex('#1A2A4A')
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                            width: dp(1)
                    Label:
                        text: "ACTUALIZACION DESDE CORREO"
                        bold: True
                        color: utils.get_color_from_hex('#00D4FF')
                        size_hint_y: None
                        height: dp(30)
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: "Asunto a buscar (vacio = cualquiera):"
                        font_size: '11sp'
                        color: utils.get_color_from_hex('#5A6A7A')
                        size_hint_y: None
                        height: dp(20)
                        halign: 'left'
                        text_size: self.size
                    TextInput:
                        id: filtro_asunto
                        hint_text: "ej: INVENTARIO  (vacio = sin filtro)"
                        multiline: False
                        size_hint_y: None
                        height: dp(40)
                        font_size: '13sp'
                    Label:
                        text: "Remitente a buscar (vacio = cualquiera):"
                        font_size: '11sp'
                        color: utils.get_color_from_hex('#5A6A7A')
                        size_hint_y: None
                        height: dp(20)
                        halign: 'left'
                        text_size: self.size
                    TextInput:
                        id: filtro_remitente
                        hint_text: "ej: jefe@empresa.com  (vacio = sin filtro)"
                        multiline: False
                        size_hint_y: None
                        height: dp(40)
                        font_size: '13sp'
                    Button:
                        text: "GUARDAR FILTROS"
                        size_hint_y: None
                        height: dp(40)
                        background_color: utils.get_color_from_hex('#0066FF')
                        on_release: root.guardar_filtros_correo()

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(145)
                    spacing: dp(8)
                    padding: dp(12)
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#0D1B2A')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(4)]
                        Color:
                            rgba: utils.get_color_from_hex('#1A2A4A')
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                            width: dp(1)
                    Label:
                        text: "EXPORTAR DATOS"
                        bold: True
                        color: utils.get_color_from_hex('#00D4FF')
                        size_hint_y: None
                        height: dp(30)
                    Label:
                        id: lbl_carpeta_export
                        text: ""
                        font_size: '11sp'
                        color: utils.get_color_from_hex('#5A6A7A')
                        size_hint_y: None
                        height: dp(28)
                        halign: 'left'
                        text_size: self.size
                        shorten: True
                        shorten_from: 'left'
                    BoxLayout:
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(50)
                        Button:
                            text: "CSV"
                            background_color: utils.get_color_from_hex('#0066FF')
                            on_release: root.exportar_csv()
                        Button:
                            text: "EXCEL"
                            background_color: utils.get_color_from_hex('#0066FF')
                            on_release: root.exportar_excel_local()

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(120)
                    spacing: dp(8)
                    padding: dp(12)
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#0D1B2A')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(4)]
                        Color:
                            rgba: utils.get_color_from_hex('#1A2A4A')
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                            width: dp(1)
                    Label:
                        text: "BACKUP AUTOMATICO"
                        bold: True
                        color: utils.get_color_from_hex('#00D4FF')
                        size_hint_y: None
                        height: dp(28)
                    BoxLayout:
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(45)
                        TextInput:
                            id: backup_interval
                            hint_text: "Cada cuantas horas? (0=desactivado)"
                            input_filter: 'int'
                            multiline: False
                            font_size: '13sp'
                        Button:
                            text: "GUARDAR"
                            size_hint_x: None
                            width: dp(100)
                            background_color: utils.get_color_from_hex('#0066FF')
                            on_release: root.guardar_backup_config()
                    Label:
                        text: "Se genera un Excel automaticamente en la carpeta de exportacion"
                        font_size: '10sp'
                        color: utils.get_color_from_hex('#5A6A7A')
                        size_hint_y: None
                        height: dp(34)
                        text_size: self.width, None
                        halign: 'left'
                        valign: 'top'

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(100)
                    spacing: dp(8)
                    padding: dp(12)
                    canvas.before:
                        Color:
                            rgba: utils.get_color_from_hex('#0D1B2A')
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(4)]
                        Color:
                            rgba: utils.get_color_from_hex('#1A2A4A')
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                            width: dp(1)
                    Label:
                        text: "ZONA DE PELIGRO"
                        bold: True
                        color: utils.get_color_from_hex('#FF0044')
                        size_hint_y: None
                        height: dp(28)
                    Button:
                        text: "PURGAR REGISTROS ANTIGUOS (+90 dias)"
                        size_hint_y: None
                        height: dp(45)
                        background_color: utils.get_color_from_hex('#FF0044')
                        on_release: root.confirmar_purga()
        
        Label:
            id: info_ajustes
            text: ""
            color: utils.get_color_from_hex('#00D4FF')
            size_hint_y: None
            height: dp(28)

        Button:
            text: "VOLVER AL INICIO"
            size_hint_y: None
            height: dp(50)
            font_size: '14sp'
            bold: True
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'

<ImportarExcelScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(12)
        spacing: dp(8)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "IMPORTAR EXCEL AL INVENTARIO"
            bold: True
            font_size: '16sp'
            color: utils.get_color_from_hex('#00D4FF')
            size_hint_y: None
            height: dp(36)

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(175)
            spacing: dp(6)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#0D1B2A')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(4)]
                Color:
                    rgba: utils.get_color_from_hex('#1A2A4A')
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                    width: dp(1)

            Label:
                text: "SELECCIONA O PEGA LA RUTA DEL ARCHIVO"
                bold: True
                font_size: '12sp'
                color: utils.get_color_from_hex('#FF0044')
                size_hint_y: None
                height: dp(22)
                halign: 'left'
                text_size: self.size

            Label:
                id: lbl_hint_carpeta
                text: ""
                font_size: '10sp'
                color: utils.get_color_from_hex('#1A2A4A')
                size_hint_y: None
                height: dp(18)
                halign: 'left'
                text_size: self.size
                shorten: True
                shorten_from: 'left'

            TextInput:
                id: ruta_excel
                hint_text: "La ruta aparece aqui al explorar o pegar"
                multiline: False
                size_hint_y: None
                height: dp(42)
                font_size: '12sp'

            BoxLayout:
                size_hint_y: None
                height: dp(44)
                spacing: dp(6)
                Button:
                    text: "EXPLORAR"
                    font_size: '13sp'
                    bold: True
                    background_color: utils.get_color_from_hex('#0066FF')
                    on_release: root.abrir_explorador()
                Button:
                    text: "PEGAR"
                    font_size: '13sp'
                    background_color: utils.get_color_from_hex('#1A2A4A')
                    on_release: root.pegar_ruta()
                Button:
                    text: "PREVISUALIZAR"
                    font_size: '13sp'
                    bold: True
                    background_color: utils.get_color_from_hex('#0066FF')
                    on_release: root.previsualizar()

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(188)
            spacing: dp(5)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#0D1B2A')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(4)]
                Color:
                    rgba: utils.get_color_from_hex('#1A2A4A')
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(4))
                    width: dp(1)

            Label:
                text: "COLUMNAS DEL EXCEL (se auto-detectan al previsualizar)"
                bold: True
                font_size: '12sp'
                color: utils.get_color_from_hex('#FF0044')
                size_hint_y: None
                height: dp(22)
                halign: 'left'
                text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(6)
                Label:
                    text: "Responsable"
                    font_size: '11sp'
                    size_hint_x: 0.28
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                TextInput:
                    id: col_nombre
                    text: "Nombre"
                    multiline: False
                    font_size: '12sp'
                Label:
                    text: "Material"
                    font_size: '11sp'
                    size_hint_x: 0.22
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                TextInput:
                    id: col_material
                    text: "Material"
                    multiline: False
                    font_size: '12sp'

            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(6)
                Label:
                    text: "SKU"
                    font_size: '11sp'
                    size_hint_x: 0.28
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                TextInput:
                    id: col_sku
                    text: "SKU"
                    multiline: False
                    font_size: '12sp'
                Label:
                    text: "Cantidad"
                    font_size: '11sp'
                    size_hint_x: 0.22
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                TextInput:
                    id: col_cantidad
                    text: "Cantidad"
                    multiline: False
                    font_size: '12sp'

            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(6)
                Label:
                    text: "Tipo"
                    font_size: '11sp'
                    size_hint_x: 0.28
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                TextInput:
                    id: col_tipo
                    text: "Tipo"
                    multiline: False
                    font_size: '12sp'
                Label:
                    text: "Fecha"
                    font_size: '11sp'
                    size_hint_x: 0.22
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                TextInput:
                    id: col_fecha
                    text: "Fecha"
                    multiline: False
                    font_size: '12sp'

            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(6)
                Label:
                    text: "Hoja Excel"
                    font_size: '11sp'
                    size_hint_x: 0.28
                    color: utils.get_color_from_hex('#5A6A7A')
                    halign: 'right'
                    text_size: self.size
                    valign: 'middle'
                Spinner:
                    id: hoja_spinner
                    text: "-- detectar --"
                    values: ["-- detectar --"]
                    font_size: '12sp'

        Label:
            id: estado_importar
            text: "Pulsa EXPLORAR para buscar tu archivo Excel"
            color: utils.get_color_from_hex('#5A6A7A')
            markup: True
            size_hint_y: None
            height: dp(36)
            halign: 'left'
            text_size: self.size
            font_size: '12sp'

        ScrollView:
            size_hint_y: 1
            do_scroll_x: False
            GridLayout:
                id: preview_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)

        Button:
            id: btn_importar
            text: "IMPORTAR AL INVENTARIO"
            bold: True
            font_size: '15sp'
            size_hint_y: None
            height: dp(52)
            background_color: utils.get_color_from_hex('#0066FF')
            disabled: True
            on_release: root.importar()

        Button:
            text: "VOLVER"
            size_hint_y: None
            height: dp(46)
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'
