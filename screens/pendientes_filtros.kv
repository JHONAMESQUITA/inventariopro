#:import utils kivy.utils
#:import dp kivy.metrics.dp

<PendientesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            padding: [dp(5), 0]
            Label:
                text: "MATERIALES FUERA"
                font_size: '18sp'
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'
                color: utils.get_color_from_hex('#FF0044')
            Button:
                text: "SYNC"
                size_hint_x: None
                width: dp(45)
                background_color: utils.get_color_from_hex('#334155')
                on_release: root.cargar_pendientes()

        TextInput:
            id: filtro_pendientes
            hint_text: "Filtrar por responsable o material..."
            multiline: False
            size_hint_y: None
            height: dp(45)
            on_text: root.cargar_pendientes()

        ScrollView:
            GridLayout:
                id: lista_pendientes
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(12)

        Button:
            text: "VOLVER AL INICIO"
            size_hint_y: None
            height: dp(50)
            font_size: '14sp'
            bold: True
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'

<FiltroScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: [dp(5), 0]
            Label:
                text: "AUDITORIA DE MOVIMIENTOS"
                font_size: '18sp'
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'
                color: utils.get_color_from_hex('#00D4FF')

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(175)
            spacing: dp(6)
            padding: dp(15)
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex('#0D1B2A')
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(4)]

            Label:
                text: "FILTROS"
                bold: True
                font_size: '12sp'
                color: utils.get_color_from_hex('#00D4FF')
                size_hint_y: None
                height: dp(20)
                text_size: self.size
                halign: 'left'

            TextInput:
                id: f_n
                hint_text: "Filtrar por Responsable..."
                multiline: False
                size_hint_y: None
                height: dp(42)
                on_text: root.filtrar()
            TextInput:
                id: f_p
                hint_text: "Filtrar por Material..."
                multiline: False
                size_hint_y: None
                height: dp(42)
                on_text: root.filtrar()
            Spinner:
                id: filtro_tipo
                text: "TODOS LOS TIPOS"
                values: ["TODOS LOS TIPOS", "ENTRADA", "SALIDA"]
                size_hint_y: None
                height: dp(42)
                on_text: root.filtrar()

        Label:
            id: filtro_count
            text: ""
            color: utils.get_color_from_hex('#5A6A7A')
            size_hint_y: None
            height: dp(25)

        ScrollView:
            GridLayout:
                id: c_r
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)

        Button:
            text: "VOLVER AL INICIO"
            size_hint_y: None
            height: dp(50)
            font_size: '14sp'
            bold: True
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'
