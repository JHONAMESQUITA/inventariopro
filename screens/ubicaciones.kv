#:import utils kivy.utils
#:import dp kivy.metrics.dp

<UbicacionesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            Label:
                text: "UBICACIONES"
                font_size: '16sp'
                bold: True
                color: utils.get_color_from_hex('#00D4FF')
                halign: 'left'
                valign: 'middle'
                text_size: self.size
            Button:
                text: "+ NUEVA"
                size_hint_x: None
                width: dp(100)
                font_size: '13sp'
                bold: True
                background_color: utils.get_color_from_hex('#0066FF')
                on_release: root.mostrar_nueva()
            Button:
                text: "VOLVER"
                size_hint_x: None
                width: dp(90)
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#334155')
                on_release: root.manager.current = 'inventario'

        ScrollView:
            GridLayout:
                id: lista_ubicaciones
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(6)
