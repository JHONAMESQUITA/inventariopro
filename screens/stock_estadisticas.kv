#:import utils kivy.utils
#:import dp kivy.metrics.dp

<StockScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: [dp(5), 0]
            Label:
                text: "ESTADO DE STOCK"
                font_size: '18sp'
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'
                color: utils.get_color_from_hex('#00D4FF')

        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(5)
            Spinner:
                id: stock_spinner
                text: "BUSCAR MATERIAL"
                values: []
                on_text: root.consultar()
            Button:
                text: ""
                size_hint_x: None
                width: dp(45)
                background_color: utils.get_color_from_hex('#334155')
                on_release: root.consultar()

        TextInput:
            id: f_s
            hint_text: "Escribe para filtrar..."
            multiline: False
            size_hint_y: None
            height: dp(45)
            on_text: root.consultar()

        BoxLayout:
            size_hint_y: None
            height: dp(35)
            spacing: dp(5)
            Button:
                text: "TODO"
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#334155')
                on_release: root.set_filtro_estado("")
            Button:
                text: "SIN STOCK"
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#FF0044')
                on_release: root.set_filtro_estado("sin_stock")
            Button:
                text: "BAJO"
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#FF0044')
                on_release: root.set_filtro_estado("bajo")
            Button:
                text: "OK"
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#0066FF')
                on_release: root.set_filtro_estado("ok")

        ScrollView:
            GridLayout:
                id: s_r
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)

        Button:
            text: "VOLVER AL INICIO"
            size_hint_y: None
            height: dp(50)
            font_size: '14sp'
            bold: True
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'

<EstadisticasScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: [dp(5), 0]
            Label:
                text: "ESTADISTICAS"
                font_size: '18sp'
                bold: True
                halign: 'left'
                text_size: self.size
                valign: 'middle'
                color: utils.get_color_from_hex('#FF0044')

        ScrollView:
            GridLayout:
                id: stats_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)

        Button:
            text: "VOLVER AL INICIO"
            size_hint_y: None
            height: dp(50)
            font_size: '14sp'
            bold: True
            background_color: utils.get_color_from_hex('#334155')
            on_release: root.manager.current = 'inventario'
