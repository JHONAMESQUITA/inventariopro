#:import utils kivy.utils
#:import dp kivy.metrics.dp

<AlertasScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            Label:
                id: total_alertas
                text: "Alertas activas: 0"
                font_size: '16sp'
                bold: True
                color: utils.get_color_from_hex('#FF0044')
                halign: 'left'
                valign: 'middle'
                text_size: self.size
            Button:
                text: "VOLVER"
                size_hint_x: None
                width: dp(90)
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#334155')
                on_release: root.manager.current = 'inventario'

        ScrollView:
            do_scroll_x: False
            GridLayout:
                id: container_alertas
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: [0, dp(5)]
