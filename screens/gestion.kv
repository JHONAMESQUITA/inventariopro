#:import utils kivy.utils
#:import dp kivy.metrics.dp

<GestionScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex('#0A0A12')
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            Label:
                id: titulo_seccion
                text: "MATERIALES"
                font_size: '16sp'
                bold: True
                color: utils.get_color_from_hex('#00D4FF')
                halign: 'left'
                valign: 'middle'
                text_size: self.size
            Button:
                text: "MATERIALES"
                size_hint_x: None
                width: dp(100)
                font_size: '11sp'
                background_color: utils.get_color_from_hex('#0066FF')
                on_release: root.cambiar_modo("materiales")
            Button:
                text: "RESPONSABLES"
                size_hint_x: None
                width: dp(110)
                font_size: '11sp'
                background_color: utils.get_color_from_hex('#0066FF')
                on_release: root.cambiar_modo("responsables")
            Button:
                text: "VOLVER"
                size_hint_x: None
                width: dp(80)
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#334155')
                on_release: root.manager.current = 'inventario'

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(6)
            TextInput:
                id: filtro_gestion
                hint_text: "Filtrar..."
                multiline: False
                font_size: '12sp'
            Button:
                text: "BUSCAR"
                size_hint_x: None
                width: dp(80)
                font_size: '12sp'
                background_color: utils.get_color_from_hex('#0066FF')
                on_release: root.filtrar()

        ScrollView:
            GridLayout:
                id: lista_gestion
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(6)
